# Gabi Personal Shopper - Backend Environment Variables Template
# Copie este arquivo para um arquivo chamado '.env' dentro da pasta 'backend' e preencha.

# Chave da API Google Gemini
GEMINI_API_KEY=sua_gemini_api_key_aqui

# Origens permitidas para requisições CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174

# Chave da API SerpApi (Google Shopping e Fichas Técnicas)
SERPAPI_KEY=sua_serpapi_key_aqui

# Chave da API Rainforest (Amazon Prices)
RAINFOREST_KEY=sua_rainforest_key_aqui
