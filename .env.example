# Gabi Personal Shopper - Frontend Environment Variables Template
# Copie este arquivo para um arquivo chamado '.env' na raiz e preencha com as suas credenciais.

# URL do servidor backend (FastAPI)
VITE_API_URL=http://localhost:8001/chat

# Configurações do Firebase
VITE_FIREBASE_API_KEY=sua_firebase_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_firebase_auth_domain_aqui
VITE_FIREBASE_PROJECT_ID=seu_firebase_project_id_aqui
VITE_FIREBASE_STORAGE_BUCKET=seu_firebase_storage_bucket_aqui
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_firebase_messaging_sender_id_aqui
VITE_FIREBASE_APP_ID=seu_firebase_app_id_aqui
VITE_FIREBASE_MEASUREMENT_ID=seu_firebase_measurement_id_aqui
